# ─── Aeterna.ia — Maestro · Template de Variáveis de Ambiente ────────────────
# Copie este arquivo: cp .env.example .env
# Preencha TODOS os valores antes de rodar localmente.
# NUNCA commite o arquivo .env no Git. Ele já está no .gitignore.
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# BANCO DE DADOS — Supabase PostgreSQL
# Encontre estes dados em: Supabase Dashboard > Project Settings > Database
# ─────────────────────────────────────────────────────────────────────────────

DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=db.XXXXXXXXXXXXXXXX.supabase.co
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=postgres
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=sua-senha-supabase-aqui
DB_POSTGRESDB_SSL_REJECT_UNAUTHORIZED=false


# ─────────────────────────────────────────────────────────────────────────────
# AUTENTICAÇÃO — Painel Web do n8n (Basic Auth)
# Protege o acesso à interface visual do orquestrador
# ─────────────────────────────────────────────────────────────────────────────

N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=troque-por-senha-forte-aqui


# ─────────────────────────────────────────────────────────────────────────────
# SEGURANÇA — Criptografia de Credenciais
# Gere com: openssl rand -hex 32
# ATENÇÃO: Se perder esta chave, TODAS as credenciais salvas serão inacessíveis
# ─────────────────────────────────────────────────────────────────────────────

N8N_ENCRYPTION_KEY=gere-uma-string-aleatoria-de-32-chars-aqui


# ─────────────────────────────────────────────────────────────────────────────
# WEBHOOKS — URL pública do serviço no Render
# Necessário para que webhooks externos apontem para o endpoint correto
# ─────────────────────────────────────────────────────────────────────────────

WEBHOOK_URL=https://aeterna-maestro.onrender.com/
N8N_HOST=aeterna-maestro.onrender.com
N8N_PROTOCOL=https


# ─────────────────────────────────────────────────────────────────────────────
# RUNTIME — Memória e Porta
# ─────────────────────────────────────────────────────────────────────────────

PORT=10000
N8N_PORT=10000
NODE_OPTIONS=--max-old-space-size=460
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=false


# ─────────────────────────────────────────────────────────────────────────────
# OPCIONAL — APIs dos Agentes Especialistas
# Adicione aqui as chaves dos modelos que o Maestro vai orquestrar
# ─────────────────────────────────────────────────────────────────────────────

# Groq (pool de 15 projetos — rotacione via Load Balancer no n8n)
GROQ_API_KEY_01=
GROQ_API_KEY_02=
GROQ_API_KEY_03=
# ... até GROQ_API_KEY_15

# Gemini (pool de 10 chaves)
GEMINI_API_KEY_01=
GEMINI_API_KEY_02=
GEMINI_API_KEY_03=
# ... até GEMINI_API_KEY_10

# Supabase (para workflows que gravam no Dataset Dourado)
SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
SUPABASE_SERVICE_ROLE_KEY=seu-service-role-key-aqui
